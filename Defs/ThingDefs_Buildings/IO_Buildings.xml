<?xml version="1.0" encoding="utf-8" ?>
<Defs>

	<ThingDef ParentName="BuildingBase">
		<defName>IO_ShipNavigationConsole</defName>
		<label>межпланетный терминал</label>
		<description>Навигационный терминал для орбитальной карты и межпланетного перелета.</description>
		<thingClass>InterstellarOdyssey.Building_ShipNavigationConsole</thingClass>

		<graphicData>
			<texPath>Things/Building/IO/ShipNavigationConsole</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(1,1)</drawSize>
		</graphicData>

		<size>(1,1)</size>
		<altitudeLayer>Building</altitudeLayer>
		<passability>PassThroughOnly</passability>
		<fillPercent>0.15</fillPercent>
		<useHitPoints>true</useHitPoints>
		<blockWind>false</blockWind>

		<costList>
			<Steel>120</Steel>
			<ComponentIndustrial>3</ComponentIndustrial>
		</costList>

		<statBases>
			<WorkToBuild>4000</WorkToBuild>
			<MaxHitPoints>180</MaxHitPoints>
			<Mass>30</Mass>
			<Flammability>0.6</Flammability>
			<Beauty>-2</Beauty>
		</statBases>

		<building>
			<isEdifice>false</isEdifice>
		</building>

		<comps>
			<li Class="CompProperties_Power">
				<compClass>CompPowerTrader</compClass>
				<basePowerConsumption>120</basePowerConsumption>
			</li>
			<li Class="CompProperties_Breakdownable" />
			<li Class="CompProperties_Flickable" />
		</comps>

		<placeWorkers>
			<li>InterstellarOdyssey.PlaceWorker_ShipNavigationConsole</li>
		</placeWorkers>

		<designationCategory>Misc</designationCategory>
		<researchPrerequisites>
			<li>MicroelectronicsBasics</li>
		</researchPrerequisites>
		<constructionSkillPrerequisite>4</constructionSkillPrerequisite>
		<rotatable>false</rotatable>
	</ThingDef>

</Defs>